{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "moduleDetection": "auto",
    "strict": true,
    "allowJs": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": false,
    "noImplicitAny": false,
    "outDir": "./build",
    "rootDir": ".",
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/env_*.*", "**/env_*"],
  "typeAcquisition": {
    "exclude": [],
  },
}
